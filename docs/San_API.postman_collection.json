	"event": [
		{
			"listen": "prerequest",
			"script": {
				"type": "text/javascript",
				"exec": [
					"var token = pm.environment.get(\"access_token\");",
					"if (token) {",
					"    pm.request.headers.add({key: \"Authorization\", value: \"Bearer \" + token});",
					"}"
				]
			}
